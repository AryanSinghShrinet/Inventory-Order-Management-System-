# Vercel deployment configuration for the React/Vite frontend.
# Import this folder at https://vercel.com/new and set VITE_API_URL
# to the deployed backend URL in the project settings.

{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
