# =============================================================================
# Copy this file to `.env` and fill in real values.
# The docker-compose setup reads variables prefixed with the service name from
# the host environment; for local development `docker compose up` will pick
# up a `.env` file located at the project root automatically.
# =============================================================================

# ---- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# ---- Backend (FastAPI) -------------------------------------------------------
# Internal Docker URL uses the service name `db`. Override in production.
DATABASE_URL=postgresql+psycopg://inventory:change_me_in_production@db:5432/inventory
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SEED_ON_START=true
LOG_LEVEL=info
# Optional: defaults to 0.0.0.0 / 8000
HOST=0.0.0.0
PORT=8000

# ---- Frontend (Vite) ---------------------------------------------------------
# Public URL of the deployed backend. Used at build-time by Vite.
VITE_API_URL=http://localhost:8000
